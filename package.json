{
  "name": "winception",
  "version": "2.0.0-alpha.2",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "web": "node tools/osdcloud-console/src/webServer.js",
    "server:preflight": "node tools/osdcloud-console/src/serverPreflight.js",
    "check:v1": "node tools/osdcloud-console/src/check.js",
    "check": "npm run check:v1 && npm run v2:check",
    "test:v1": "node --test \"tools/osdcloud-console/test/**/*.test.js\"",
    "test": "npm run test:v1 && npm run v2:test",
    "smoke": "node tools/osdcloud-console/src/smoke.js",
    "reload": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/Reload-Console.ps1",
    "v2:dev:agent": "tsx apps/agent/src/main.ts",
    "v2:dev:server": "tsx apps/server/src/main.ts",
    "v2:dev:web": "vite --config apps/web/vite.config.ts",
    "v2:typecheck": "tsc -p tsconfig.check.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit && tsc -p apps/docs/tsconfig.json --noEmit",
    "v2:lint": "eslint apps packages Scripts/v2 --max-warnings=0",
    "v2:cycles": "node Scripts/v2/check-dependencies.mjs",
    "v2:docs:check": "node Scripts/v2/check-doc-budgets.mjs",
    "v2:diagrams:write": "node Scripts/v2/generate-diagrams.mjs --write",
    "v2:diagrams:check": "node Scripts/v2/generate-diagrams.mjs --check",
    "v2:check": "npm run v2:typecheck && npm run v2:lint && npm run v2:cycles && npm run v2:docs:check && npm run v2:diagrams:check && npm run v2:powershell:check && npm run v2:installer-signature:test",
    "v2:test": "node --import tsx --test \"apps/**/*.test.ts\" \"packages/**/*.test.ts\"",
    "v2:test:coverage": "node --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=70 --import tsx --test \"apps/**/*.test.ts\" \"packages/**/*.test.ts\"",
    "v2:test:critical-coverage": "c8 --all --per-file --check-coverage --lines 90 --branches 85 --include packages/contracts/src/index.ts --include packages/application/src/operationCoordinator.ts --include packages/infrastructure/src/database.ts --include packages/infrastructure/src/deploymentSecrets.ts --include packages/infrastructure/src/evidence.ts --include packages/infrastructure/src/productState.ts --include packages/infrastructure/src/v1Importer.ts --include packages/infrastructure/src/ipc.ts node --import tsx --test \"apps/**/*.test.ts\" \"packages/**/*.test.ts\"",
    "v2:e2e": "playwright test",
    "v2:openapi:write": "tsx Scripts/v2/openapi.ts --write",
    "v2:openapi:check": "tsx Scripts/v2/openapi.ts --check",
    "v2:secrets": "powershell -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File tools/v2/Test-Secrets.ps1",
    "v2:powershell:check": "powershell -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File tools/v2/Test-PowerShellSyntax.ps1",
    "v2:installer-signature:test": "powershell -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File Scripts/v2/Test-InstallerBootstrapSignature.ps1",
    "docs:assets:write": "node Scripts/v2/build-doc-assets.mjs --write",
    "docs:assets:check": "node Scripts/v2/build-doc-assets.mjs --check",
    "docs:check": "npm run docs:assets:check && node Scripts/v2/check-interactive-docs.mjs",
    "docs:start": "docusaurus start apps/docs --host 127.0.0.1 --port 19090",
    "docs:build:pages": "npm run docs:assets:write && cross-env DOCS_BASE_URL=/winception/ docusaurus build apps/docs --out-dir ../../dist/docs-pages",
    "docs:build:offline": "npm run docs:assets:write && cross-env DOCS_BASE_URL=/manual/ docusaurus build apps/docs --out-dir ../../dist/v2/web/manual && node Scripts/v2/generate-csp-hashes.mjs dist/v2/web/manual",
    "docs:e2e": "playwright test --config playwright.docs.config.ts",
    "v2:build:node": "tsc -p tsconfig.node.json",
    "v2:build:web": "vite build --config apps/web/vite.config.ts",
    "v2:build": "npm run v2:check && npm run docs:check && npm run v2:build:node && npm run v2:build:web && npm run docs:build:offline",
    "v2:start:agent": "node dist/v2/node/apps/agent/src/main.js",
    "v2:start:server": "node dist/v2/node/apps/server/src/main.js",
    "v2:migrate:v1": "node dist/v2/node/apps/agent/src/migrateV1.js"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "@fastify/swagger": "^9.8.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.52",
    "bencode": "^4.0.1",
    "bittorrent-protocol": "^5.0.6",
    "create-torrent": "^6.1.2",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@docusaurus/core": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "c8": "^11.0.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.1.4",
    "webpack": "5.105.2"
  }
}
