<service>
  <id>Winception.Web</id>
  <name>Winception Web</name>
  <description>Hosts the low-privilege Winception management interface.</description>
  <executable>%BASE%\node.exe</executable>
  <arguments>&quot;%BASE%\..\app\dist\v2\node\apps\server\src\main.js&quot;</arguments>
  <workingdirectory>%BASE%\..\app</workingdirectory>
  <stoptimeout>30sec</stoptimeout>
  <logpath>%ProgramData%\Winception\State\logs\web</logpath>
  <log mode="roll" />
</service>
